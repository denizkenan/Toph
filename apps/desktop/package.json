{
  "name": "@toph/desktop",
  "version": "0.0.1",
  "private": true,
  "description": "Toph is a modern dictation software",
  "author": "YourTechBud <noorain@yourtechbud.studio>",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "build": "pnpm run rebuild:native && pnpm --workspace-root run icons:app && electron-vite build",
    "dev": "pnpm --workspace-root run icons:app && TOPH_DATA_DIRECTORY=../../.toph ELECTRON_DISABLE_SANDBOX=1 electron-vite dev",
    "dist": "pnpm run build && electron-builder",
    "dist:linux": "pnpm run build && electron-builder --linux --publish never",
    "dist:mac": "pnpm run build && electron-builder --mac --arm64 --x64 --publish never",
    "dist:win": "pnpm run build && electron-builder --win --publish never",
    "pack": "pnpm run build && electron-builder --dir",
    "preview": "pnpm --workspace-root run icons:app && TOPH_DATA_DIRECTORY=../../.toph ELECTRON_DISABLE_SANDBOX=1 electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "test:polish": "node --experimental-strip-types --test test/polish/*.test.ts",
    "test:segmentation": "node --experimental-strip-types --test test/segmentation/*.test.ts",
    "test:settings": "node --experimental-strip-types --test test/settings/*.test.ts",
    "test:shortcuts": "node --experimental-strip-types --test test/shortcuts/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "@toph/desktop-contracts": "workspace:*",
    "@toph/desktop-ui": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.1",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-kit": "^0.31.10",
    "electron": "^37.3.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}

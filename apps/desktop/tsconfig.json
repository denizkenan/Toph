{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@toph/desktop-contracts": ["../../packages/desktop-contracts/src/index.ts"],
      "@toph/desktop-ui": ["../../packages/desktop-ui/src/index.ts"]
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vite/client", "electron"]
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "src/renderer/**/*",
    "../../packages/desktop-contracts/src/**/*",
    "../../packages/desktop-ui/src/**/*"
  ],
  "exclude": ["../../packages/desktop-ui/src/**/*.test.tsx"]
}
